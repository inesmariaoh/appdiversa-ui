# =============================================================================
# AppDiversa UI — variables de entorno (ejemplo)
# Copiar a .env.local para desarrollo local:
#   cp .env.example .env.local
# =============================================================================

# URL base del backend Django REST Framework (obligatoria en despliegue)
# Visible en el navegador del usuario (peticiones client-side).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# URL del backend solo para SSR (opcional).
# Util en Docker cuando el contenedor no puede usar 127.0.0.1 del host.
# En Vercel suele bastar con NEXT_PUBLIC_API_BASE_URL si el backend es publico.
# API_BASE_URL=http://host.docker.internal:8000

# Google Analytics 4 (opcional, integracion futura)
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Microsoft Clarity (opcional, integracion futura)
# NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx

# OAuth social via Keycloak (opcional)
# NEXT_PUBLIC_KEYCLOAK_GOOGLE_URL=
# NEXT_PUBLIC_KEYCLOAK_FACEBOOK_URL=

# URL de terminos y condiciones en registro (opcional)
# NEXT_PUBLIC_URL_TERMINOS=

# Keycloak general (opcional, integracion futura)
# NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
# NEXT_PUBLIC_KEYCLOAK_REALM=appdiversa
# NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=appdiversa-ui
