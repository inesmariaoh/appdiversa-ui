        mime_type:
          type: string
          maxLength: 150
        tamano_bytes:
          type: integer
          maximum: 18446744073709551615
          minimum: 0
          format: int64
        checksum_sha256:
          type: string
          maxLength: 64
        tipo_archivo:
          $ref: '#/components/schemas/TipoArchivoEnum'
        es_publico:
          type: boolean
        origen:
          $ref: '#/components/schemas/OrigenEnum'
