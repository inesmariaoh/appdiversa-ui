openapi: 3.0.3
info:
  title: AppDiversa API
  version: v1
  description: API REST del motor de formularios parametrizables AppDiversa 2.0
paths:
  /api/v1/analitica/respuestas/:
    get:
      operationId: v1_analitica_respuestas_list
      description: Endpoint de datos analiticos. Requiere token temporal de API interna
        hasta integrar Keycloak.
      summary: Listar respuestas analiticas
      parameters:
      - in: header
        name: X-API-INTERNA
        schema:
          type: string
        description: Token temporal de API interna. Será reemplazado por Keycloak
          en una fase posterior.
      - in: query
        name: estado_sesion
        schema:
          type: string
        description: Estado de la sesion anonima.
      - in: query
        name: fecha_fin
        schema:
          type: string
        description: Fecha final de sesion en formato ISO.
      - in: query
        name: fecha_inicio
        schema:
          type: string
        description: Fecha inicial de sesion en formato ISO.
      - in: query
        name: formulario_codigo
        schema:
          type: string
        description: Codigo del formulario a filtrar.
      tags:
      - Analitica
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/RespuestaAnalitica'
          description: ''
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorAnalitica'
          description: ''
  /api/v1/archivos/:
    post:
      operationId: v1_archivos_create
      description: Registra un archivo en el repositorio documental transversal. Requiere
        sesion anonima valida o token de API interna temporal.
      summary: Subir archivo al repositorio
      parameters:
      - in: header
        name: X-API-INTERNA
        schema:
          type: string
        description: Token temporal de API interna. Será reemplazado por Keycloak
          en una fase posterior.
      - in: header
        name: X-Sesion-Anonima
        schema:
          type: string
        description: UUID de la sesion anonima asociada a la operacion.
      - in: header
        name: X-Token-Sesion
        schema:
          type: string
        description: Token de sesion anonima emitido al crear la sesion.
      tags:
      - Archivos
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/SubirArchivoEntrada'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/SubirArchivoEntrada'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/SubirArchivoEntrada'
        required: true
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ArchivoRepositorio'
          description: ''
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorArchivo'
          description: ''
  /api/v1/archivos/{uuid_archivo}/:
    get:
      operationId: v1_archivos_retrieve
      description: Retorna metadatos del archivo solicitado.
      summary: Consultar metadatos de archivo
      parameters:
      - in: header
        name: X-API-INTERNA
        schema:
          type: string
        description: Token temporal de API interna. Será reemplazado por Keycloak
          en una fase posterior.
      - in: path
        name: uuid_archivo
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Archivos
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ArchivoRepositorio'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorArchivo'
          description: ''
    delete:
      operationId: v1_archivos_destroy
      description: Realiza soft delete del archivo en el repositorio documental.
      summary: Eliminar archivo del repositorio
      parameters:
      - in: header
        name: X-API-INTERNA
        schema:
          type: string
        description: Token temporal de API interna. Será reemplazado por Keycloak
          en una fase posterior.
      - in: path
        name: uuid_archivo
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Archivos
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ArchivoRepositorio'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorArchivo'
          description: ''
  /api/v1/archivos/{uuid_archivo}/descargar/:
    get:
      operationId: v1_archivos_descargar_retrieve
      description: Retorna el contenido binario del archivo solicitado.
      summary: Descargar archivo del repositorio
      parameters:
      - in: header
        name: X-API-INTERNA
        schema:
          type: string
        description: Token temporal de API interna. Será reemplazado por Keycloak
          en una fase posterior.
      - in: path
        name: uuid_archivo
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Archivos
      responses:
        '200':
          description: Contenido binario del archivo.
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorArchivo'
          description: ''
  /api/v1/catalogos/:
    get:
      operationId: v1_catalogos_list
      description: Retorna la lista de catalogos parametrizables activos para consumo
        del frontend.
      summary: Listar catalogos activos
      parameters:
      - in: query
        name: idioma
        schema:
          type: string
        description: Codigo ISO del idioma para traducciones de contenido.
      tags:
      - Catalogos
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/Catalogo'
          description: ''
  /api/v1/catalogos/{codigo_catalogo}/items/:
    get:
      operationId: v1_catalogos_items_list
      description: Retorna los items de un catalogo parametrizable. Permite filtrar
        por item padre para jerarquias como pais, departamento y municipio.
      summary: Listar items de un catalogo
      parameters:
      - in: query
        name: busqueda
        schema:
          type: string
        description: Filtra items por nombre o codigo.
      - in: path
        name: codigo_catalogo
        schema:
          type: string
        required: true
      - in: query
        name: codigo_padre
        schema:
          type: string
        description: Codigo del item padre para filtrar hijos.
      - in: query
        name: idioma
        schema:
          type: string
        description: Codigo ISO del idioma para traducciones de contenido.
      - in: query
        name: incluir_accesibilidad
        schema:
          type: boolean
        description: Si es verdadero, incluye contenido accesible multimodal en la
          respuesta.
      - in: query
        name: limite
        schema:
          type: integer
        description: Limita la cantidad de items retornados (maximo 1000).
      - in: query
        name: solo_activos
        schema:
          type: boolean
        description: Si es verdadero, solo retorna items activos.
      tags:
      - Catalogos
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/ItemCatalogo'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorCatalogo'
          description: ''
  /api/v1/catalogos/{codigo_catalogo}/items/{codigo_item}/hijos/:
    get:
      operationId: v1_catalogos_items_hijos_list
      description: Retorna los items hijos directos de un item dentro de su catalogo.
      summary: Listar hijos de un item de catalogo
      parameters:
      - in: path
        name: codigo_catalogo
        schema:
          type: string
        required: true
      - in: path
        name: codigo_item
        schema:
          type: string
        required: true
      - in: query
        name: idioma
        schema:
          type: string
        description: Codigo ISO del idioma para traducciones de contenido.
      - in: query
        name: incluir_accesibilidad
        schema:
          type: boolean
        description: Si es verdadero, incluye contenido accesible multimodal en la
          respuesta.
      - in: query
        name: solo_activos
        schema:
          type: boolean
        description: Si es verdadero, solo retorna items activos.
      tags:
      - Catalogos
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/ItemCatalogo'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorCatalogo'
          description: ''
  /api/v1/exportaciones/{uuid_exportacion}/:
    get:
      operationId: v1_exportaciones_retrieve
      description: Retorna el detalle de una exportacion.
      summary: Consultar exportacion
      parameters:
      - in: header
        name: X-API-INTERNA
        schema:
          type: string
        description: Token temporal de API interna. Será reemplazado por Keycloak
          en una fase posterior.
      - in: path
        name: uuid_exportacion
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Exportaciones
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Exportacion'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorExportacion'
          description: ''
  /api/v1/exportaciones/analitica/:
    post:
      operationId: v1_exportaciones_analitica_create
      description: Ejecuta exportacion de analitica.
      summary: Exportar analitica
      parameters:
      - in: header
        name: X-API-INTERNA
        schema:
          type: string
        description: Token temporal de API interna. Será reemplazado por Keycloak
          en una fase posterior.
      tags:
      - Exportaciones
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ExportacionAnaliticaEntrada'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ExportacionAnaliticaEntrada'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ExportacionAnaliticaEntrada'
        required: true
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Exportacion'
          description: ''
  /api/v1/exportaciones/catalogos/:
    post:
      operationId: v1_exportaciones_catalogos_create
      description: Ejecuta exportacion de catalogos.
      summary: Exportar catalogos
      parameters:
      - in: header
        name: X-API-INTERNA
        schema:
          type: string
        description: Token temporal de API interna. Será reemplazado por Keycloak
          en una fase posterior.
      tags:
      - Exportaciones
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ExportacionCatalogosEntrada'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ExportacionCatalogosEntrada'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ExportacionCatalogosEntrada'
        required: true
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Exportacion'
          description: ''
  /api/v1/exportaciones/respuestas/:
    post:
      operationId: v1_exportaciones_respuestas_create
      description: Ejecuta exportacion de respuestas segun filtros.
      summary: Exportar respuestas
      parameters:
      - in: header
        name: X-API-INTERNA
        schema:
          type: string
        description: Token temporal de API interna. Será reemplazado por Keycloak
          en una fase posterior.
      tags:
      - Exportaciones
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ExportacionRespuestasEntrada'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ExportacionRespuestasEntrada'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ExportacionRespuestasEntrada'
        required: true
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Exportacion'
          description: ''
  /api/v1/formularios/{uuid_formulario}/estructura/:
    get:
      operationId: v1_formularios_estructura_retrieve
      description: Retorna la estructura completa del formulario publicado, incluyendo
        textos, secciones, preguntas, opciones y reglas.
      summary: Obtener estructura de formulario
      parameters:
      - in: query
        name: idioma
        schema:
          type: string
        description: Codigo ISO del idioma para traducciones de contenido.
      - in: path
        name: uuid_formulario
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Formularios
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/FormularioEstructura'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorFormulario'
          description: Formulario no disponible o sin version publicada.
  /api/v1/formularios/disponibles/:
    get:
      operationId: v1_formularios_disponibles_list
      description: Retorna la lista de formularios publicados y vigentes para renderizacion
        dinamica en el frontend.
      summary: Listar formularios disponibles
      parameters:
      - in: query
        name: idioma
        schema:
          type: string
        description: Codigo ISO del idioma para traducciones de contenido.
      tags:
      - Formularios
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/FormularioDisponible'
          description: ''
  /api/v1/interfaz/configuracion/:
    get:
      operationId: v1_interfaz_configuracion_retrieve
      description: Retorna la parametrizacion visual activa del aplicativo para renderizacion
        dinamica en el frontend.
      summary: Obtener configuracion de interfaz
      parameters:
      - in: query
        name: idioma
        schema:
          type: string
        description: Codigo ISO del idioma para traducciones de contenido.
      - in: query
        name: incluir_accesibilidad
        schema:
          type: boolean
        description: Si es verdadero, incluye contenido accesible multimodal en la
          respuesta.
      tags:
      - Interfaz
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ConfiguracionInterfazPublicaEsquema'
          description: ''
  /api/v1/internacionalizacion/traducciones/:
    get:
      operationId: v1_internacionalizacion_traducciones_list
      description: Retorna traducciones activas con contenido textual y accesible
        multimodal. Los archivos se retornan como URLs absolutas cuando existen.
      summary: Listar traducciones de contenido
      parameters:
      - in: query
        name: campo
        schema:
          type: string
        description: Nombre del campo traducido.
      - in: query
        name: entidad
        schema:
          type: string
        description: Nombre de la entidad traducible (Formulario, Pregunta, etc.).
      - in: query
        name: entidad_uuid
        schema:
          type: string
        description: UUID de la entidad traducida.
      - in: query
        name: idioma
        schema:
          type: string
        description: Codigo ISO del idioma para filtrar traducciones.
      tags:
      - Internacionalizacion
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/TraduccionContenido'
          description: ''
  /api/v1/notificaciones/:
    get:
      operationId: v1_notificaciones_list
      description: Retorna las notificaciones registradas.
      summary: Listar notificaciones
      parameters:
      - in: header
        name: X-API-INTERNA
        schema:
          type: string
        description: Token temporal de API interna. Será reemplazado por Keycloak
          en una fase posterior.
      tags:
      - Notificaciones
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/Notificacion'
          description: ''
  /api/v1/notificaciones/{uuid_notificacion}/:
    get:
      operationId: v1_notificaciones_retrieve
      description: Retorna el detalle de una notificacion.
      summary: Consultar notificacion
      parameters:
      - in: header
        name: X-API-INTERNA
        schema:
          type: string
        description: Token temporal de API interna. Será reemplazado por Keycloak
          en una fase posterior.
      - in: path
        name: uuid_notificacion
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Notificaciones
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Notificacion'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorNotificacion'
          description: ''
  /api/v1/notificaciones/probar/:
    post:
      operationId: v1_notificaciones_probar_create
      description: Genera y registra una notificacion sin enviarla a proveedores externos.
        Requiere token temporal de API interna hasta integrar Keycloak.
      summary: Probar generacion de notificacion
      parameters:
      - in: header
        name: X-API-INTERNA
        schema:
          type: string
        description: Token temporal de API interna. Será reemplazado por Keycloak
          en una fase posterior.
      tags:
      - Notificaciones
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ProbarNotificacionEntrada'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ProbarNotificacionEntrada'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ProbarNotificacionEntrada'
        required: true
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Notificacion'
          description: ''
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorNotificacion'
          description: ''
  /api/v1/respuestas/:
    post:
      operationId: v1_respuestas_create
      description: Crea o actualiza una respuesta para una pregunta dentro de una
        sesion anonima. El backend determina el campo de almacenamiento segun el tipo
        de pregunta.
      summary: Guardar o actualizar respuesta
      parameters:
      - in: header
        name: X-Sesion-Anonima
        schema:
          type: string
        description: UUID de la sesion anonima asociada a la operacion.
      - in: header
        name: X-Token-Sesion
        schema:
          type: string
        description: Token de sesion anonima emitido al crear la sesion.
      tags:
      - Respuestas
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/GuardarRespuestaEntrada'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/GuardarRespuestaEntrada'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/GuardarRespuestaEntrada'
        required: true
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GuardarRespuestaSalida'
          description: ''
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GuardarRespuestaSalida'
          description: ''
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorRespuesta'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorRespuesta'
          description: ''
  /api/v1/salud/:
    get:
      operationId: v1_salud_retrieve
      description: Confirma que el servicio API responde correctamente.
      summary: Verificar salud del servicio
      tags:
      - v1
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SaludRespuesta'
          description: ''
  /api/v1/sesiones/:
    post:
      operationId: v1_sesiones_create
      description: Registra una sesion anonima asociada a un formulario publicado
        o reutiliza una sesion existente por uuid_sesion. Si no se envia token_cliente,
        el backend genera uno seguro.
      summary: Crear o reutilizar sesion anonima
      tags:
      - Sesiones
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CrearSesionAnonimaEntrada'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/CrearSesionAnonimaEntrada'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/CrearSesionAnonimaEntrada'
        required: true
      security:
      - {}
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SesionAnonima'
          description: ''
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SesionAnonima'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorSesion'
          description: ''
  /api/v1/sesiones/{uuid_sesion}/evaluar-reglas/:
    post:
      operationId: v1_sesiones_evaluar_reglas_create
      description: Evalua las reglas condicionales activas del formulario segun las
        respuestas registradas en la sesion.
      summary: Evaluar reglas de sesion
      parameters:
      - in: header
        name: X-Sesion-Anonima
        schema:
          type: string
        description: UUID de la sesion anonima asociada a la operacion.
      - in: header
        name: X-Token-Sesion
        schema:
          type: string
        description: Token de sesion anonima emitido al crear la sesion.
      - in: path
        name: uuid_sesion
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Reglas
      - Sesiones
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ResultadoReglas'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorSesion'
          description: ''
  /api/v1/sesiones/{uuid_sesion}/finalizar/:
    post:
      operationId: v1_sesiones_finalizar_create
      description: Finaliza la sesion si todas las preguntas obligatorias tienen respuesta
        util.
      summary: Finalizar formulario de sesion
      parameters:
      - in: header
        name: X-Sesion-Anonima
        schema:
          type: string
        description: UUID de la sesion anonima asociada a la operacion.
      - in: header
        name: X-Token-Sesion
        schema:
          type: string
        description: Token de sesion anonima emitido al crear la sesion.
      - in: path
        name: uuid_sesion
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Sesiones
      - Respuestas
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/FinalizacionFormulario'
          description: ''
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ValidacionFinalizacion'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorSesion'
          description: ''
  /api/v1/sesiones/{uuid_sesion}/preguntas/{codigo_pregunta}/evaluar-reglas/:
    post:
      operationId: v1_sesiones_preguntas_evaluar_reglas_create
      description: Evalua las reglas cuya pregunta origen coincide con el codigo indicado,
        segun las respuestas de la sesion.
      summary: Evaluar reglas por pregunta
      parameters:
      - in: header
        name: X-Sesion-Anonima
        schema:
          type: string
        description: UUID de la sesion anonima asociada a la operacion.
      - in: header
        name: X-Token-Sesion
        schema:
          type: string
        description: Token de sesion anonima emitido al crear la sesion.
      - in: path
        name: codigo_pregunta
        schema:
          type: string
        required: true
      - in: path
        name: uuid_sesion
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Reglas
      - Sesiones
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ResultadoReglas'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorSesion'
          description: ''
  /api/v1/sesiones/{uuid_sesion}/respuestas/:
    get:
      operationId: v1_sesiones_respuestas_retrieve
      description: Retorna todas las respuestas guardadas para una sesion anonima.
      summary: Listar respuestas de sesion
      parameters:
      - in: header
        name: X-Sesion-Anonima
        schema:
          type: string
        description: UUID de la sesion anonima asociada a la operacion.
      - in: header
        name: X-Token-Sesion
        schema:
          type: string
        description: Token de sesion anonima emitido al crear la sesion.
      - in: path
        name: uuid_sesion
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Sesiones
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/RespuestasSesion'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorSesion'
          description: ''
  /api/v1/sesiones/{uuid_sesion}/resumen/:
    get:
      operationId: v1_sesiones_resumen_retrieve
      description: Retorna el resumen de respuestas activas de la sesion.
      summary: Resumen de respuestas de sesion
      parameters:
      - in: header
        name: X-Sesion-Anonima
        schema:
          type: string
        description: UUID de la sesion anonima asociada a la operacion.
      - in: header
        name: X-Token-Sesion
        schema:
          type: string
        description: Token de sesion anonima emitido al crear la sesion.
      - in: path
        name: uuid_sesion
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Sesiones
      - Respuestas
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ResumenFormularioSesion'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorSesion'
          description: ''
  /api/v1/sesiones/{uuid_sesion}/validar-finalizacion/:
    post:
      operationId: v1_sesiones_validar_finalizacion_create
      description: Verifica que todas las preguntas obligatorias de la sesion tengan
        una respuesta util.
      summary: Validar finalizacion de formulario
      parameters:
      - in: header
        name: X-Sesion-Anonima
        schema:
          type: string
        description: UUID de la sesion anonima asociada a la operacion.
      - in: header
        name: X-Token-Sesion
        schema:
          type: string
        description: Token de sesion anonima emitido al crear la sesion.
      - in: path
        name: uuid_sesion
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Sesiones
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ValidacionFinalizacion'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorSesion'
          description: ''
  /api/v1/sincronizacion/:
    post:
      operationId: v1_sincronizacion_create
      description: Procesa un lote de operaciones enviadas por un dispositivo offline.
        Cada operacion se valida con uuid_local y version_cliente para garantizar
        idempotencia. Los conflictos se resuelven con Last Write Wins y se registran
        sin perder informacion. Una operacion fallida no cancela el resto del lote.
      summary: Sincronizar lote de respuestas offline
      parameters:
      - in: header
        name: X-Sesion-Anonima
        schema:
          type: string
        description: UUID de la sesion anonima asociada a la operacion.
      - in: header
        name: X-Token-Sesion
        schema:
          type: string
        description: Token de sesion anonima emitido al crear la sesion.
      tags:
      - Sincronizacion
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/SincronizarBatchEntrada'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/SincronizarBatchEntrada'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/SincronizarBatchEntrada'
        required: true
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SincronizarBatchSalida'
          description: ''
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorSincronizacion'
          description: ''
        '403':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorSincronizacion'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DetalleErrorSincronizacion'
          description: ''
